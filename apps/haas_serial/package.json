{
  "name": "haas_serial",
  "type": "module",
  "version": "1.0.0",
  "description": "Haas Serial Post status gatherer for the Shop App",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=false -r dotenv/config ./src/index.ts",
    "build": "rimraf ./dist && tsc",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check",
    "ci": "biome ci",
    "check-types": "tsc --noEmit"
  },
  "engineStrict": true,
  "dependencies": {
    "@repo/utilities": "workspace:*",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "http-terminator": "^3.2.0",
    "morgan": "^1.10.1",
    "remote-serial-port-client": "^0.4.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.4.0",
    "@types/shop-app": "workspace:*",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  }
}
