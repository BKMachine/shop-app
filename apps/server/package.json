{
  "name": "server",
  "type": "module",
  "version": "1.0.0",
  "description": "Server for the Shop App",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=false -r dotenv/config ./src/index.ts",
    "build": "rimraf ./dist && tsc -p tsconfig.build.json",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "check-types": "tsc --noEmit",
    "repair:images": "tsx -r dotenv/config ./scripts/repair_image_database.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest.config.cjs",
    "fixture:pdf-text": "tsx ./scripts/pdf_fixture_text_pdf.ts",
    "database:derived": "tsx -r dotenv/config ./scripts/add_derived_properties.ts"
  },
  "dependencies": {
    "@repo/utilities": "workspace:*",
    "axios": "^1.15.2",
    "bwip-js": "^4.10.1",
    "cron": "^4.4.0",
    "express": "^5.2.1",
    "http-terminator": "^3.2.0",
    "luxon": "^3.7.2",
    "mongoose": "^9.6.0",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "socket.io": "^4.8.3",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/shop-app": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "jest": "^30.3.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
