{
  "name": "server",
  "type": "module",
  "version": "1.0.0",
  "description": "Server for the Shop App",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch --clear-screen=false -r dotenv/config ./src/index.ts",
    "build": "rimraf ./dist && tsc",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check --write",
    "ci": "biome ci",
    "check-types": "tsc --noEmit",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config ./jest.config.cjs"
  },
  "dependencies": {
    "@repo/utilities": "workspace:*",
    "axios": "^1.13.5",
    "cron": "^4.4.0",
    "express": "^5.2.1",
    "http-terminator": "^3.2.0",
    "luxon": "^3.7.2",
    "mongoose": "^9.2.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/shop-app": "workspace:*",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
