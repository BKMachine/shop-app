{
  "name": "@repo/utilities",
  "type": "module",
  "private": true,
  "license": "MIT",
  "exports": {
    "./constants": {
      "import": "./dist/constants.js",
      "types": "./dist/constants.d.ts"
    },
    "./logger": {
      "import": "./dist/logger.js",
      "types": "./dist/logger.d.ts"
    },
    "./main": {
      "import": "./dist/main.js",
      "types": "./dist/main.d.ts"
    },
    "./materials": {
      "import": "./dist/materials.js",
      "types": "./dist/materials.d.ts"
    },
    "./parts": {
      "import": "./dist/parts.js",
      "types": "./dist/parts.d.ts"
    }
  },
  "scripts": {
    "build": "rimraf ./dist && tsc",
    "dev": "tsc --watch --preserveWatchOutput",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "check": "biome check",
    "ci": "biome ci",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "hono": "^4.12.15",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.6.0",
    "@types/shop-app": "workspace:*",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
